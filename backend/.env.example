PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/ctf_platform
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://192.168.1.100:3000
FRONTEND_URL=http://192.168.1.100:3000
AUTO_RECALC_SCORES_ON_BOOT=true

# SMTP for real email verification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=CyberCTF <your-email@example.com>

# A default admin is auto-created at first boot if no admin exists.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@ctf.com
ADMIN_PASSWORD=admin123
